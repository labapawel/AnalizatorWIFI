<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:AnalizatorWiFi.UI.Services"
        x:Class="AnalizatorWiFi.UI.Views.ConnectDialog"
        Title="{Binding [Dialog.Title], Source={x:Static loc:LocalizationService.Instance}}"
        Width="400"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="14">

        <!-- SSID row -->
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding [Dialog.Network], Source={x:Static loc:LocalizationService.Instance}}"
                       FontWeight="SemiBold"/>
            <TextBox x:Name="SsidBox" FontSize="13"/>
        </StackPanel>

        <!-- Password row — hidden for open networks -->
        <StackPanel x:Name="PasswordPanel" Spacing="4">
            <TextBlock Text="{Binding [Dialog.Password], Source={x:Static loc:LocalizationService.Instance}}"/>
            <TextBox x:Name="PasswordBox" PasswordChar="●" FontSize="13"/>
            <TextBlock x:Name="ShowPasswordToggle"
                       Text="{Binding [Dialog.ShowPassword], Source={x:Static loc:LocalizationService.Instance}}"
                       Cursor="Hand"
                       FontSize="11"
                       Foreground="{DynamicResource SystemAccentColor}"
                       TextDecorations="Underline"/>
        </StackPanel>

        <!-- Open network notice -->
        <Border x:Name="OpenNotice"
                Background="{DynamicResource SystemBaseLowColor}"
                CornerRadius="4" Padding="10,6">
            <TextBlock Text="{Binding [Dialog.OpenNetwork], Source={x:Static loc:LocalizationService.Instance}}"
                       FontSize="12"
                       Foreground="{DynamicResource SystemBaseMediumColor}"/>
        </Border>

        <!-- Status -->
        <TextBlock x:Name="StatusText"
                   FontSize="12"
                   Foreground="#e74c3c"
                   IsVisible="False"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,4,0,0">
            <Button x:Name="CancelBtn"
                    Content="{Binding [Dialog.Cancel], Source={x:Static loc:LocalizationService.Instance}}"
                    Width="80"/>
            <Button x:Name="ConnectBtn"
                    Content="{Binding [Dialog.Connect], Source={x:Static loc:LocalizationService.Instance}}"
                    Width="90" Classes="accent"/>
        </StackPanel>

    </StackPanel>
</Window>
